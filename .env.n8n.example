# ============================================
# n8n Configuration
# ============================================

# Autenticación básica
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar_esto_en_produccion

# Configuración de red
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/

# Zona horaria
GENERIC_TIMEZONE=America/Santiago
TZ=America/Santiago

# Almacenamiento de ejecuciones
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_MAX_AGE=168  # 7 días en horas

# ============================================
# Backend FastAPI Configuration
# ============================================

# URL del webhook de n8n (para que el backend dispare workflows)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/search

# API Key para autenticar comunicación backend <-> n8n
N8N_API_KEY=tu-super-secreto-api-key-12345

# ============================================
# MySQL Project Database Configuration
# ============================================

# Si tu MySQL corre localmente (no en Docker)
PROJECT_MYSQL_HOST=localhost
PROJECT_MYSQL_PORT=3306
PROJECT_MYSQL_DATABASE=webscraping
PROJECT_MYSQL_USER=root
PROJECT_MYSQL_PASSWORD=tu_password

# Si tu MySQL corre en Docker, usar:
# PROJECT_MYSQL_HOST=host.docker.internal  (desde n8n hacia tu PC)
# PROJECT_MYSQL_HOST=mysql_webscraping     (si está en el mismo docker-compose)

# ============================================
# Google Custom Search API (para n8n)
# ============================================

GOOGLE_SEARCH_API_KEY=tu_google_api_key
GOOGLE_SEARCH_ENGINE_ID=tu_search_engine_id

# ============================================
# INSTRUCCIONES
# ============================================
#
# 1. Copia este archivo a .env.n8n:
#    cp .env.n8n.example .env.n8n
#
# 2. Edita .env.n8n con tus valores reales
#
# 3. Si usas docker-compose, actualiza el archivo para leer estas variables:
#    environment:
#      - N8N_BASIC_AUTH_USER=${N8N_BASIC_AUTH_USER}
#      - N8N_BASIC_AUTH_PASSWORD=${N8N_BASIC_AUTH_PASSWORD}
#      etc...
#
# 4. NO SUBAS .env.n8n A GIT (agrega a .gitignore)
#
